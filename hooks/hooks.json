{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/auto-prime.sh",
            "timeout": 15,
            "statusMessage": "Auto-priming CommitMind context..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/auto-post-compact.sh",
            "timeout": 10,
            "statusMessage": "Re-grounding CommitMind context after compaction..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/history-shaped-prompt.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/prompt-memory-fan-out.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/anchor-user-work.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/harvest-finding.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/rules-prefetch.sh",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/routing-enforce.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/explain-prefetch.sh",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/anchor-user-work.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/anchor-edit.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/surface-playbook.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/subagent-preload.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__commitmind__task_create",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/playbooks-for-task.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/task-phase-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/count-edit.sh",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/check-edit.sh",
            "timeout": 6
          }
        ]
      },
      {
        "matcher": "mcp__commitmind-code__xref",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/routing-enforce.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__commitmind__task_todo_add",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/anchor-user-work.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "mcp__commitmind__task_set_active",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/playbooks-for-task.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/scripts/stuck-design.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
